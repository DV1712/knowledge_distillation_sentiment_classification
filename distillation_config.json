{
  "description": "Grid search configuration for multi-teacher feature extraction and classification",
  "seed": 42,
  "dataset": {
    "general_sentiment_analysis_dataset": {
      "dataset_file_name_old": "dataset/multiclass_sentiments.jsonl",
      "dataset_file_name": "dataset/sentiment_data_abdel.csv",
      "test_size": 0.2,
      "val_split": 0.5
    }
  },
  "models": [
    {
      "name": "BERT",
      "model_id": "bert-base-uncased"
    },
    {
      "name": "RoBERTa_old",
      "model_id": "roberta-base"
    },
    {
      "name": "RoBERTa",
      "model_id": "cardiffnlp/twitter-roberta-base-sentiment-latest"
    },
    {
      "name": "DistilBERT_old",
      "model_id": "distilbert-base-uncased"
    },
    {
      "name": "DistilBERT",
      "model_id": "distilbert-base-uncased-finetuned-sst-2-english"
    },
    {
      "name": "GPT-2",
      "model_id": "gpt2"
    },
    {
      "name": "MobileBERT",
      "model_id": "google/mobilebert-uncased"
    },
    {
      "name": "T5",
      "model_id": "t5-small"
    },
    {
      "name": "ModernBERT",
      "model_id": "google/bert_uncased_L-4_H-512_A-8"
    },
    {
      "name": "EttinDecoder",
      "model_id": "microsoft/ettin-decoder-1.5b"
    }
  ],
  "feature_extraction": {
    "batch_size": 256,
    "max_length": 256
  },
  "model_config":{
    "BERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "RoBERTa":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512,256,128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    
    "DistilBERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.05],
      "lr_options": [0.0003],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "DistilBERT_new": {
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[256, 64]],
      "dropout_options": [0.3],
      "lr_options": [0.001],
      "n_splits": 5,
      "patience": 10
    },
    "GPT-2":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "T5":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "ModernBERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "EttinDecoder":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "MobileBERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    }
  },
  "training": {
    "min_delta": 0.0,
    "gradient_clip_norm": 1.0,
    "optimizer": "Adam"
  },
  "evaluation": {
    "latency_batch_size": 256
  },
  "distillation": {
    "enabled": true,
    "alpha": 0.5,
    "temperature": 2.5,
    "student_config": {
      "hidden_dims": [16, 8, 4],
      "dropout": 0.1,
      "learning_rate": 0.0003,
      "batch_size": 128,
      "epochs": 200,
      "patience": 10
    },
    "output_dir": "distillation_metrics",
    "multi_teacher_output_dir": "multi_teacher_distillation_metrics"
  },
  "distillation-multi-teacher": {
    "enabled": true,
    "alpha": 0.5,
    "temperature": 2.5,
    "student_config": {
      "hidden_dims": [16, 8],
      "dropout": 0.1,
      "learning_rate": 0.003,
      "batch_size": 128,
      "epochs": 200,
      "patience": 10
    },
    "output_dir": "distillation_metrics",
    "multi_teacher_output_dir": "multi_teacher_distillation_metrics"
  },
  "output": {
    "pipeline_metrics_dir": "pipeline_metrics",
    "multi_teacher_output_dir": "multi_teacher_distillation_metrics",
    "multi_teacher_plots_dir": "multi_teacher_plots",
    "results_csv": "multi_teacher_classification_results.csv",
    "grid_results_csv": "grid_search_all_configs.csv",
    "grid_search_best_results_csv": "grid_search_best_configs.csv"
  }
}
