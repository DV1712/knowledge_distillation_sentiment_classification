{
  "description": "Grid search configuration for multi-teacher feature extraction and classification",
  "seed": 42,
  "data": {
    "data_file": "dataset/multiclass_sentiments.jsonl",
    "test_size": 0.2,
    "val_split": 0.5
  },
  "models": [
    {
      "name": "BERT",
      "model_id": "bert-base-uncased"
    },
    {
      "name": "RoBERTa",
      "model_id": "roberta-base"
    },
    {
      "name": "DistilBERT",
      "model_id": "distilbert-base-uncased"
    },
    {
      "name": "GPT-2",
      "model_id": "gpt2"
    },
    {
      "name": "T5",
      "model_id": "google-t5/t5-base"
    },
    {
      "name": "ModernBERT",
      "model_id": "answerdotai/ModernBERT-base"
    },
    {
      "name": "EttinDecoder",
      "model_id": "jhu-clsp/ettin-decoder-17m"
    }
  ], 
  "feature_extraction": {
    "batch_size": 64,
    "max_length": 256
  },
  "grid_search": {
    "epochs_options": [200],
    "batch_size_options": [32, 64, 128],
    "hidden_dims_options": [[256], [512], [256, 128], [512, 256]],
    "dropout_options": [0.1, 0.3, 0.5],
    "lr_options": [0.0001, 0.0003, 0.001],
    "n_splits": 5,
    "patience": 3,
    "show_epoch_progress": true
  },
  "model_config":{
    "BERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "RoBERTa":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512,256,128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "DistilBERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "GPT-2":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "T5":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "ModernBERT":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    },
    "EttinDecoder":{
      "epochs_options": [200],
      "batch_size_options": [128],
      "hidden_dims_options": [[512, 256, 128, 64]],
      "dropout_options": [0.1],
      "lr_options": [0.00005],
      "n_splits": 5,
      "patience": 10,
      "show_epoch_progress": true
    }
  },
  "training": {
    "min_delta": 0.0,
    "gradient_clip_norm": 1.0,
    "optimizer": "Adam"
  },
  "evaluation": {
    "latency_batch_size": 256
  },
  "distillation": {
    "enabled": true,
    "alpha": 0.5,
    "temperature": 1.0,
    "student_config": {
      "hidden_dims": [256, 128, 64, 32],
      "dropout": 0.1,
      "learning_rate": 0.00005,
      "batch_size": 64,
      "epochs": 200,
      "patience": 10
    },
    "output_dir": "distillation_metrics"
  },
  "output": {
    "results_csv": "multi_teacher_classification_results.csv",
    "grid_results_csv": "grid_search_all_configs.csv",
    "grid_search_best_results_csv": "grid_search_best_configs.csv"
  },
  "notes": {
    "epochs_adjustment": "If early stopping consistently triggers before epoch 15-20, reduce epochs_options to [20, 30, 40] or similar",
    "lr_reduction": "Currently using only lr=3e-4. Restore full lr_options for comprehensive search",
    "quick_test_preset": {
      "epochs_options": [20],
      "batch_size_options": [64],
      "hidden_dims_options": [[256]],
      "dropout_options": [0.3],
      "lr_options": [0.00005],
      "n_splits": 3
    }
  }
}
